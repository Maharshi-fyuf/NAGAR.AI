rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /issues/{issueId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.category in ['pothole','streetlight','garbage','water','drainage','other']
        && request.resource.data.severity in ['low','medium','high','critical'];
      allow update: if request.auth != null && (
        resource.data.reportedBy == request.auth.uid ||
        onlyUpdatingVoteFields(request)
      );
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.uid == userId;
    }

    function onlyUpdatingVoteFields(req) {
      let allowed = ['upvotes', 'verificationCount', 'updatedAt', 
                     'status', 'timeline', 'complaintLetter'];
      return req.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(allowed);
    }
  }
}
